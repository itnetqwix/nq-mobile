# Public vars only — inlined at bundle time by Expo (must use EXPO_PUBLIC_ prefix).
# Copy to `.env` before running:  cp .env.example .env
# No spaces around "=". Restart Metro after edits: npx expo start -c
EXPO_PUBLIC_API_BASE_URL=https://api-netqwix.com
# If login fails on phone but works on laptop: school/work/public Wi‑Fi often blocks api.* (category filter). Use cellular or home Wi‑Fi, or ask IT to allow this host.

# Must match the real web app origin (Origin / Referer headers). Default: https://www.netqwix.com
# EXPO_PUBLIC_WEB_ORIGIN=https://www.netqwix.com

# Optional: full URL to the Next.js ICE route (`nq-frontend-main/app/api/peer/route.js`). Defaults to `{EXPO_PUBLIC_WEB_ORIGIN}/api/peer`.
# EXPO_PUBLIC_ICE_CONFIG_URL=https://www.netqwix.com/api/peer

# Set to 1 to log every API request/response in the Metro terminal (passwords redacted).
# EXPO_PUBLIC_DEBUG_HTTP=1

# Default: React Native HTTP (reliable JSON bodies, e.g. login). Set to 1 to use Expo native fetch if you need it for TLS/WAF.
# EXPO_PUBLIC_USE_EXPO_FETCH=1
