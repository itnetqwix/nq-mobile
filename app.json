{
  "expo": {
    "name": "NetQwix",
    "slug": "netqwix",
    "scheme": "netqwix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/netqwix_logo-fulll.png",
      "resizeMode": "contain",
      "backgroundColor": "#000080"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "127.0.0.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        },
        "NSCameraUsageDescription": "NetQwix needs camera access so you can join lessons over video.",
        "NSMicrophoneUsageDescription": "NetQwix needs microphone access so you can talk to your coach or trainee during a lesson.",
        "NSBluetoothPeripheralUsageDescription": "NetQwix uses Bluetooth so you can answer calls on connected headphones.",
        "NSBluetoothAlwaysUsageDescription": "NetQwix uses Bluetooth to connect to wireless headsets and speakers during coaching sessions.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification",
          "picture-in-picture"
        ],
        "NSPhotoLibraryUsageDescription": "NetQwix accesses your photo library to upload training clips to your locker.",
        "NSPhotoLibraryAddUsageDescription": "NetQwix saves session screenshots to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bitcode": false,
      "bundleIdentifier": "com.netqwix.nqmobile"
    },
    "android": {
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "supportsPictureInPicture": true,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000080"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_PHONE_CALL",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_PHONE_NUMBERS",
        "android.permission.CALL_PHONE",
        "android.permission.MANAGE_OWN_CALLS",
        "android.permission.BIND_TELECOM_CONNECTION_SERVICE",
        "android.permission.WAKE_LOCK",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "package": "com.netqwix.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000080",
          "image": "./assets/netqwix_logo-fulll.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "NetQwix needs access to your photo library so you can upload training video clips to your locker.",
          "cameraPermission": "NetQwix can use the camera if you record a clip to upload."
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "NetQwix needs camera access so you can join lessons over video.",
          "microphonePermission": "NetQwix needs microphone access so you can talk to your coach or trainee during a lesson."
        }
      ],
      [
        "react-native-permissions",
        {
          "iosPermissions": [
            "Camera",
            "Microphone"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#000080",
          "defaultChannel": "default",
          "sounds": [
            "./assets/sounds/instant-lesson-ring.wav"
          ]
        }
      ],
      "@config-plugins/react-native-callkeep",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.netqwix.nqmobile",
          "enableGooglePay": true
        }
      ],
      "expo-web-browser",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "fc0cbae6-e93e-4661-8a6b-0339b19391ad"
      },
      "devdudes": {
        "url": "https://devdudes.dev",
        "label": "DEVDUDES"
      }
    },
    "owner": "netqwix"
  }
}
