{
  "name": "nq-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start --go",
    "start:tunnel": "expo start --dev-client --tunnel",
    "print:expo-url": "node scripts/print-expo-lan-url.js",
    "expo:start": "expo start",
    "android": "expo run:android",
    "android:install-dev": "bash scripts/install-android-dev-client.sh",
    "android:rebuild-dev": "bash -c 'source scripts/android-dev-env.sh && cd android && ./gradlew app:assembleDebug'",
    "android:reverse": "bash scripts/android-metro-reverse.sh",
    "dev:metro": "bash scripts/dev-metro.sh",
    "dev:log:android": "bash scripts/dev-log-android.sh",
    "dev:log:ios": "bash scripts/dev-log-ios.sh",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device \"iPhone\" --no-bundler",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "build:testflight": "eas build --platform ios --profile production",
    "build:play-internal": "eas build --platform android --profile production",
    "build:dev": "eas build --platform ios --profile development",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "submit:testflight": "eas submit --platform ios --profile production --latest",
    "submit:android": "eas submit --platform android --profile production --latest",
    "submit:play-internal": "eas submit --platform android --profile production --latest",
    "deploy:ios": "eas build --platform ios --profile production --auto-submit",
    "deploy:testflight": "eas build --platform ios --profile production --auto-submit",
    "deploy:android": "eas build --platform android --profile production --auto-submit",
    "deploy:play-internal": "eas build --platform android --profile production --auto-submit",
    "store:preflight": "bash scripts/store-preflight.sh",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "sync:api-contract": "npx --yes tsx scripts/sync-openapi-contract.ts",
    "test": "jest",
    "test:phase4": "jest --testPathPattern=\"paymentEdgeCases.phase4|paymentStatusLabels|pricingQuoteHint|bookingWalletGuard|walletPaymentOptionLogic|walletTopUpFlowLogic\"",
    "test:payment-flow": "node scripts/run-payment-flow-coverage.mjs",
    "test:payment-flow:unit": "jest --testPathPattern=\"wizardPaymentLogic|pricingTypes|pricingQuoteHint|currency.test|stripeConnectLogic|trainerEarningsDisplayLogic|walletBalanceDisplayLogic\" --forceExit",
    "test:e2e:validate": "node scripts/validate-maestro-flows.mjs",
    "test:watch": "jest --watch",
    "test:e2e": "maestro test e2e/maestro",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@config-plugins/react-native-callkeep": "^12.0.0",
    "@config-plugins/react-native-webrtc": "13.0.0",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.1.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.15.13",
    "@react-navigation/drawer": "^7.9.11",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.14.14",
    "@reduxjs/toolkit": "^2.12.0",
    "@shopify/flash-list": "^2.3.2",
    "@shopify/react-native-skia": "2.2.12",
    "@stripe/stripe-react-native": "^0.65.1",
    "@tanstack/query-async-storage-persister": "^5.100.11",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-persist-client": "^5.100.11",
    "axios": "^1.16.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.2.0",
    "luxon": "^3.7.2",
    "netqwix-meeting-native": "file:./modules/netqwix-meeting-native",
    "react": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-callkeep": "^4.3.16",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-pager-view": "6.9.1",
    "react-native-permissions": "^5.5.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "^5.1.0",
    "react-native-webrtc": "124.0.6",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.3.0",
    "socket.io-client": "^4.8.3",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.1",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "private": true
